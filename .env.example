# Supabase (server-side only — never expose the secret key to the client)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Resend (transactional email)
RESEND_API_KEY=

# Contact/careers notification recipients (CSV)
ADMIN_EMAILS=

# --- Vietnam Adventure info form ---
# Where submission notifications are emailed (defaults to accounting@edge8.ai)
TRIP_NOTIFY_EMAIL=accounting@edge8.ai
# Lark incoming webhook URL for submission notifications (optional; skipped if unset)
LARK_WEBHOOK_URL=
# Trip END date (YYYY-MM-DD). Passport photos are auto-deleted 30 days after this.
TRIP_END_DATE=
# Optional secret to authenticate the Vercel cron that runs the passport cleanup
CRON_SECRET=
